<?xml version="1.0"?>
<robot name="bronchoscope">

  <link name="world"/>
  <joint name="world_fixed" type="fixed">
    <parent link="world"/>
    <child link="rail_link"/>
    <origin xyz="-0.1 0 0.485" rpy="0 0 0"/>
  </joint>

  <link name="rail_link">
    <inertial><mass value="1.0"/><inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/></inertial>
  </link>

  <joint name="insertion_joint" type="prismatic">
    <parent link="rail_link"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.5" upper="1.5" effort="100.0" velocity="0.5"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="-0.15 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.015" length="0.3"/></geometry>
      <material name="gray"><color rgba="0.7 0.7 0.7 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="-0.15 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.015" length="0.3"/></geometry>
    </collision>
    <inertial><mass value="1.0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <gazebo reference="base_link"><material>Gazebo/Grey</material><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>

  <joint name="proximal_yaw_joint" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/> 
    <axis xyz="0 0 1"/> 
    <limit lower="-0.6" upper="0.6" effort="100.0" velocity="1.0"/>
  </joint>

  <link name="link_1">
    <visual>
      <origin xyz="0.05 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.014" length="0.1"/></geometry>
      <material name="dark_gray"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0.05 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.014" length="0.1"/></geometry>
    </collision>
    <inertial><mass value="0.2"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>
  <gazebo reference="link_1"><material>Gazebo/DarkGrey</material><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>

  <joint name="proximal_pitch_joint" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0.1 0 0" rpy="0 0 0"/> 
    <axis xyz="0 1 0"/> 
    <limit lower="-0.6" upper="0.6" effort="100.0" velocity="1.0"/>
  </joint>

  <link name="link_2">
    <visual>
      <origin xyz="0.05 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.013" length="0.1"/></geometry>
      <material name="gray"><color rgba="0.6 0.6 0.6 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0.05 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.013" length="0.1"/></geometry>
    </collision>
    <inertial><mass value="0.2"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>
  <gazebo reference="link_2"><material>Gazebo/Grey</material><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>

  <joint name="mid_yaw_joint" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="0.1 0 0" rpy="0 0 0"/> 
    <axis xyz="0 0 1"/> 
    <limit lower="-1.0" upper="1.0" effort="100.0" velocity="1.0"/>
  </joint>

  <link name="link_3">
    <visual>
      <origin xyz="0.05 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.013" length="0.1"/></geometry>
      <material name="dark_gray"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0.05 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.013" length="0.1"/></geometry>
    </collision>
    <inertial><mass value="0.2"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>
  <gazebo reference="link_3"><material>Gazebo/DarkGrey</material><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>

  <joint name="mid_pitch_joint" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0.1 0 0" rpy="0 0 0"/> 
    <axis xyz="0 1 0"/> 
    <limit lower="-1.0" upper="1.0" effort="100.0" velocity="1.0"/>
  </joint>

  <link name="link_4">
    <visual>
      <origin xyz="0.05 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.012" length="0.1"/></geometry>
      <material name="gray"><color rgba="0.6 0.6 0.6 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0.05 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.012" length="0.1"/></geometry>
    </collision>
    <inertial><mass value="0.2"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/></inertial>
  </link>
  <gazebo reference="link_4"><material>Gazebo/Grey</material><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>

  <joint name="distal_yaw_joint" type="revolute">
    <parent link="link_4"/>
    <child link="link_5"/>
    <origin xyz="0.1 0 0" rpy="0 0 0"/> 
    <axis xyz="0 0 1"/> 
    <limit lower="-1.57" upper="1.57" effort="100.0" velocity="1.0"/>
  </joint>

  <link name="link_5">
    <visual>
      <origin xyz="0.025 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.012" length="0.05"/></geometry>
      <material name="dark_gray"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0.025 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.012" length="0.05"/></geometry>
    </collision>
    <inertial><mass value="0.1"/><inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/></inertial>
  </link>
  <gazebo reference="link_5"><material>Gazebo/DarkGrey</material><mu1>0.0</mu1><mu2>0.0</mu2></gazebo>

  <joint name="distal_roll_joint" type="revolute">
    <parent link="link_5"/>
    <child link="distal_tip"/>
    <origin xyz="0.05 0 0" rpy="0 0 0"/> 
    <axis xyz="1 0 0"/> 
    <limit lower="-3.14" upper="3.14" effort="50.0" velocity="2.0"/>
  </joint>

  <link name="distal_tip">
    <visual>
      <origin xyz="0.025 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.012" length="0.05"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0.025 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.012" length="0.05"/></geometry>
    </collision>
    <collision>
      <origin xyz="0.05 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.012"/></geometry>
    </collision>
    <inertial><mass value="0.1"/><inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/></inertial>
  </link>

  <gazebo reference="distal_tip">
    <material>Gazebo/Black</material>
    <mu1>0.0</mu1><mu2>0.0</mu2>
    <sensor name="cmos_camera" type="camera">
      <pose>0.05 0 0 0 0 0</pose> 
      <always_on>true</always_on>
      <update_rate>30.0</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image><width>640</width><height>480</height><format>R8G8B8</format></image>
        <clip><near>0.01</near><far>10.0</far></clip>
      </camera>
    </sensor>
    <light name="cold_led" type="spot">
      <pose>0.05 0 0 0 0 0</pose> 
      <direction>1 0 0</direction>
      <attenuation><range>2.0</range><linear>0.05</linear><constant>0.1</constant><quadratic>0.001</quadratic></attenuation>
      <diffuse>0.9 0.9 1.0 1</diffuse>
      <specular>0.1 0.1 0.1 1</specular>
      <spot><inner_angle>0.5</inner_angle><outer_angle>1.2</outer_angle><falloff>1.0</falloff></spot>
      <cast_shadows>true</cast_shadows>
    </light>
  </gazebo>

  <ros2_control name="GazeboSimSystem" type="system">
    <hardware><plugin>gz_ros2_control/GazeboSimSystem</plugin></hardware>
    
    <joint name="insertion_joint">
      <command_interface name="position">
        <param name="min">-0.5</param>
        <param name="max">1.5</param>
        <param name="p">1000.0</param>
        <param name="i">0.0</param>
        <param name="d">10.0</param>
      </command_interface>
      <state_interface name="position"/>
    </joint>
    
    <joint name="proximal_yaw_joint">
      <command_interface name="position">
        <param name="min">-0.6</param>
        <param name="max">0.6</param>
        <param name="p">500.0</param>
        <param name="i">0.0</param>
        <param name="d">5.0</param>
      </command_interface>
      <state_interface name="position"/>
    </joint>
    
    <joint name="proximal_pitch_joint">
      <command_interface name="position">
        <param name="min">-0.6</param>
        <param name="max">0.6</param>
        <param name="p">500.0</param>
        <param name="i">0.0</param>
        <param name="d">5.0</param>
      </command_interface>
      <state_interface name="position"/>
    </joint>
    
    <joint name="mid_yaw_joint">
      <command_interface name="position">
        <param name="min">-1.0</param>
        <param name="max">1.0</param>
        <param name="p">200.0</param>
        <param name="i">0.0</param>
        <param name="d">2.0</param>
      </command_interface>
      <state_interface name="position"/>
    </joint>
    
    <joint name="mid_pitch_joint">
      <command_interface name="position">
        <param name="min">-1.0</param>
        <param name="max">1.0</param>
        <param name="p">200.0</param>
        <param name="i">0.0</param>
        <param name="d">2.0</param>
      </command_interface>
      <state_interface name="position"/>
    </joint>
    
    <joint name="distal_yaw_joint">
      <command_interface name="position">
        <param name="min">-1.57</param>
        <param name="max">1.57</param>
        <param name="p">100.0</param>
        <param name="i">0.0</param>
        <param name="d">1.0</param>
      </command_interface>
      <state_interface name="position"/>
    </joint>
    
    <joint name="distal_roll_joint">
      <command_interface name="position">
        <param name="min">-3.14</param>
        <param name="max">3.14</param>
        <param name="p">50.0</param>
        <param name="i">0.0</param>
        <param name="d">0.5</param>
      </command_interface>
      <state_interface name="position"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find smart_endoscope)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>
</robot>